{
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/dist",
  "devCommand": "cd web && npm run dev",
  "env": {
    "VITE_API_URL": "@VITE_API_URL"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
